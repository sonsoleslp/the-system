generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}

model Virus {
  id           Int    @id @default(autoincrement())
  genus        String
  species      String
  name         String
  abbreviation String
  designation  String
  createdAt    DateTime @default(now())
  trials       Trial[]
}

model Trial {
  id              Int      @id @default(autoincrement())
  status          String   // "SUCCESS" or "FAIL"
  name            String
  virusId         Int
  virus           Virus    @relation(fields: [virusId], references: [id])
  geneticSequence String?  // Random genetic sequence
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
